{
  "name": "angular-project",
  "version": "0.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "ng": "ng",
    "prestart": "npm run build:workspaces",
    "start": "ng serve",
    "prebuild": "npm run build:workspaces",
    "build": "ng build",
    "prewatch": "npm run build:workspaces",
    "watch": "ng build --watch --configuration development",
    "pretest": "npm run build:workspaces",
    "test": "npm run test:auth-state && npm run test:profile-angular && npm run test:react-ui && npm run test:legal-react && ng test",
    "build:auth-state": "npm run build -w @drivewise/auth-state",
    "build:profile-angular": "npm run build -w @drivewise/profile-angular",
    "build:react-ui": "npm run build -w @drivewise/react-ui",
    "build:legal-react": "npm run build -w @drivewise/legal-react",
    "build:workspaces": "npm run build:auth-state && npm run build:profile-angular && npm run build:react-ui && npm run build:legal-react",
    "test:auth-state": "npm run test -w @drivewise/auth-state",
    "test:profile-angular": "npm run build:auth-state && npm run test -w @drivewise/profile-angular",
    "test:react-ui": "npm run test -w @drivewise/react-ui",
    "test:legal-react": "npm run build:auth-state && npm run build:react-ui && npm run test -w @drivewise/legal-react"
  },
  "private": true,
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@drivewise/auth-state": "^0.1.0",
    "@drivewise/legal-react": "^0.1.0",
    "@drivewise/profile-angular": "^0.1.0",
    "@drivewise/react-ui": "^0.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
