{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true, "declaration": true, "esModuleInterop": true,
    "jsx": "react-jsx", "lib": ["DOM", "ES2022"], "module": "ES2022",
    "moduleResolution": "Bundler", "outDir": "dist", "rootDir": "src",
    "skipLibCheck": true, "strict": true, "target": "ES2022"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.spec.tsx"]
}
